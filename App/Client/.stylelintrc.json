{
  "extends": [
    "stylelint-config-standard-scss",
    "stylelint-plugin-carbon-tokens/config/recommended"
  ],
  "plugins": [
    "stylelint-plugin-carbon-tokens"
  ],
  "rules": {
    "selector-class-pattern": null,
    "carbon/theme-use": [
      true,
      {
        "acceptCarbonCustomProp": true,
        "acceptValues": [
          "/inherit|initial|none|unset/",
          "/currentColor|transparent/",
          "/^0$/"
        ],
        "severity": "error"
      }
    ],
    "carbon/layout-use": [
      true,
      {
        "includeProps": [
          "*",
          "/^width$/",
          "/^height$/",
          "/^min-width$/",
          "/^max-width$/",
          "/^min-height$/",
          "/^max-height$/"
        ],
        "acceptCarbonCustomProp": true,
        "acceptValues": [
          "/^0$/",
          "auto",
          "/mini-units/",
          "/inherit|initial|none|unset/",
          "/^-{0,1}[0-9]*(%|vw|vh)$/",
          "/calc/"
        ],
        "severity": "error"
      }
    ],
    "carbon/motion-duration-use": [
      true,
      {
        "acceptCarbonCustomProp": true,
        "acceptValues": [
          "/^0$/"
        ],
        "severity": "error"
      }
    ],
    "carbon/motion-easing-use": [
      true,
      {
        "severity": "error"
      }
    ],
    "carbon/type-use": [
      true,
      {
        "acceptCarbonCustomProp": true,
        "acceptValues": [
          "/inherit|initial|none|unset/"
        ],
        "severity": "error"
      }
    ]
  }
}
