{
  "extends": [
    "stylelint-config-standard-scss",
    "stylelint-plugin-carbon-tokens/config/recommended"
  ],
  "plugins": [
    "stylelint-plugin-carbon-tokens"
  ],
  "rules": {
    "selector-class-pattern": null,
    "carbon/theme-use": [
      true,
      {
        "acceptCarbonCustomProp": true,
        "acceptValues": [
          "/inherit|initial|none|unset/",
          "/currentColor|transparent/",
          "white",
          "/rgb\\(/",
          "/^0$/"
        ],
        "severity": "error"
      }
    ],
    "carbon/layout-use": [
      true,
      {
        "acceptCarbonCustomProp": true,
        "acceptValues": [
          "/^0$/",
          "auto",
          "/mini-units/"
        ],
        "severity": "error"
      }
    ],
    "carbon/motion-duration-use": [
      true,
      {
        "acceptCarbonCustomProp": true,
        "acceptValues": [
          "/^0$/"
        ],
        "severity": "error"
      }
    ],
    "carbon/motion-easing-use": [
      true,
      {
        "severity": "error"
      }
    ],
    "carbon/type-use": [
      true,
      {
        "acceptCarbonCustomProp": true,
        "acceptValues": [
          "/inherit|initial|none|unset/",
          "/1\\.8/"
        ],
        "severity": "error"
      }
    ]
  }
}
