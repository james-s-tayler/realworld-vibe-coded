{
  "Audit": {
    "LogsPath": "../../../../../../../Logs/Test/Server/Server.Web/Audit.NET"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Error",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "Microsoft.AspNetCore": "Error",
        "Microsoft.Hosting.Lifetime": "Error",
        "System": "Error",
        "Finbuckle.MultiTenant": "Information",
        "Server.UseCases.Identity": "Error"
      }
    },
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "SourceContext = 'Server.SharedKernel.MediatR.TransactionBehavior'"
        }
      },
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "SourceContext = 'Server.Infrastructure.Data.UnitOfWork'"
        }
      },
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestPath like '/api/identity%' and SourceContext = 'Microsoft.EntityFrameworkCore.Database.Command'"
        }
      }
    ],
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "../../../../../../../Logs/Test/Server/Server.Web/Serilog/logs.json",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "FeatureFlagSettings": {
    "RefreshIntervalSeconds": 30
  },
  "feature_management": {
    "feature_flags": [
      { "id": "DisabledFeature", "enabled": false },
      { "id": "SampleFeature", "enabled": true },
      {
        "id": "TargetingTestFlag",
        "enabled": true,
        "conditions": {
          "client_filters": [
            {
              "name": "Microsoft.Targeting",
              "parameters": {
                "Audience": {
                  "DefaultRolloutPercentage": 50
                }
              }
            }
          ]
        }
      }
    ]
  },
  "OpenTelemetry": {
    "OtlpEndpoint": ""
  }
}
